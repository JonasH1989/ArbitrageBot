# MPC Arbitrage Bot Dockerfile
FROM python:3.11-slim

WORKDIR /app

# Install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy bot files
COPY arbitrage_bot.py .
COPY arbitrage_multi.py .

# Copy config directory
COPY config/ ./config/

# Create directories
RUN mkdir -p logs

# Run multi-pair bot
CMD ["python", "arbitrage_multi.py"]
